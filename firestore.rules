rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function adminData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn()
        && (
          adminData().role == "admin"
          || adminData().role == "Admin"
          || adminData().admin == true
          || adminData().isAdmin == true
        );
    }

    function ownerKeepsProtectedFieldsSafe() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return !changedKeys.hasAny([
        "role",
        "admin",
        "isAdmin",
        "personLinkDecision"
      ])
      && ownerKeepsLinkFieldsSafe(changedKeys);
    }

    function hasStoredLinkId() {
      return resource.data.keys().hasAny(["linkedPersonId"])
        || resource.data.keys().hasAny(["personId"]);
    }

    function ownerKeepsLinkFieldsSafe(changedKeys) {
      return (!changedKeys.hasAny(["personLinked"])
        || request.resource.data.personLinked == false)
      && (!changedKeys.hasAny(["personId"])
        || !request.resource.data.keys().hasAny(["personId"]))
      && (!changedKeys.hasAny(["linkedPersonId"])
        || !request.resource.data.keys().hasAny(["linkedPersonId"]))
      && (!changedKeys.hasAny(["personLinkStatus"])
        || (
          request.resource.data.personLinkStatus in ["open", "requested", "rejected", "withdrawn"]
          && (request.resource.data.personLinkStatus != "requested" || !hasStoredLinkId())
        ))
      && ownerKeepsLinkRequestSafe(changedKeys)
      && ownerKeepsLinkIssueSafe(changedKeys);
    }

    function ownerKeepsLinkRequestSafe(changedKeys) {
      return !changedKeys.hasAny(["personLinkRequest"])
        || !request.resource.data.keys().hasAny(["personLinkRequest"])
        || !request.resource.data.personLinkRequest.keys().hasAny(["status"])
        || (
          request.resource.data.personLinkRequest.status in ["requested", "rejected", "withdrawn"]
          && (request.resource.data.personLinkRequest.status != "requested" || !hasStoredLinkId())
        );
    }

    function ownerKeepsLinkIssueSafe(changedKeys) {
      return !changedKeys.hasAny(["personLinkIssue"])
        || !request.resource.data.keys().hasAny(["personLinkIssue"])
        || (
          hasStoredLinkId()
          && request.resource.data.personLinkIssue.keys().hasOnly([
            "status",
            "message",
            "accountEmail",
            "accountName",
            "accountUid",
            "reportedAt",
            "withdrawnAt",
            "updatedAt"
          ])
          && request.resource.data.personLinkIssue.keys().hasAny(["status"])
          && request.resource.data.personLinkIssue.status in ["reported", "withdrawn"]
        );
    }

    function ownerCreatesOnlySportlerAccount() {
      return (!("role" in request.resource.data) || request.resource.data.role == "sportler")
        && !request.resource.data.keys().hasAny(["admin", "isAdmin"]);
    }

    function adminKeepsAdminGrantSafe() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return (!changedKeys.hasAny(["role"])
        || request.resource.data.role in ["sportler", "kader-sportler", "organisator", "organizer"])
        && (!changedKeys.hasAny(["admin"]) || request.resource.data.admin == false)
        && (!changedKeys.hasAny(["isAdmin"]) || request.resource.data.isAdmin == false);
    }

    match /users/{uid} {
      allow create: if isOwner(uid) && ownerCreatesOnlySportlerAccount();
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow update: if (isAdmin() && adminKeepsAdminGrantSafe())
        || (isOwner(uid) && ownerKeepsProtectedFieldsSafe());
      allow delete: if isAdmin() || isOwner(uid);
    }
  }
}
